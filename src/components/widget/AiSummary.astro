---
import { Icon } from "astro-icon/components";

interface Props {
  articleId: string;
  title: string;
  content: string;
}

const { articleId, title, content } = Astro.props;
const cacheKey = `ai_summary_${articleId}`;
---

<details class="ai-summary-card" open>
  <summary class="ai-summary-header">
    <Icon name="material-symbols:auto-awesome" class="text-[1rem] text-(--primary)" />
    <span class="font-medium text-sm">AI 总结</span>
    <Icon class="chevron ml-auto transition-transform" name="material-symbols:expand-more" />
  </summary>
  
  <div class="ai-summary-content">
    <div class="ai-summary-loading" style="display: none;">
      <div class="flex items-center gap-2 text-neutral-500 dark:text-neutral-400 text-sm">
        <span class="loading-dots">
          <span class="dot">.</span><span class="dot">.</span><span class="dot">.</span>
        </span>
        <span>AI 正在生成摘要...</span>
      </div>
    </div>
    
    <div class="ai-summary-text text-sm leading-relaxed text-neutral-600 dark:text-neutral-300" style="display: none;">
    </div>
    
    <div class="ai-summary-error text-sm text-red-500 dark:text-red-400" style="display: none;">
    </div>
  </div>
</details>

<style>
  .ai-summary-card {
    background: var(--license-block-bg, #f9fafb);
    border: 1px solid var(--line-divider, #e5e7eb);
    border-radius: 0.75rem;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .ai-summary-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
    list-style: none;
    color: var(--text-primary, #1f2937);
    transition: background-color 0.2s ease;
  }

  .ai-summary-header:hover {
    background-color: rgba(0, 0, 0, 0.03);
  }

  .dark .ai-summary-header:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }

  .ai-summary-header::-webkit-details-marker {
    display: none;
  }

  .ai-summary-card:not([open]) .chevron {
    transform: rotate(-90deg);
  }

  .ai-summary-content {
    padding: 0 1rem 1rem 1rem;
  }

  .loading-dots .dot {
    animation: blink 1.4s infinite both;
    display: inline-block;
  }

  .loading-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .loading-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes blink {
    0%, 80%, 100% {
      opacity: 0;
    }
    40% {
      opacity: 1;
    }
  }
</style>

<script define:vars={{ cacheKey, articleId, title, content }}>
  (function() {
    const card = document.querySelector('.ai-summary-card');
    const loadingEl = document.querySelector('.ai-summary-loading');
    const textEl = document.querySelector('.ai-summary-text');
    const errorEl = document.querySelector('.ai-summary-error');
    const header = document.querySelector('.ai-summary-header');
    
    if (!card || !loadingEl || !textEl || !errorEl) return;

    const CACHE_EXPIRY = 24 * 60 * 60 * 1000;
    
    function getCache() {
      try {
        const cached = localStorage.getItem(cacheKey);
        if (!cached) return null;
        const data = JSON.parse(cached);
        if (Date.now() - data.timestamp > CACHE_EXPIRY) {
          localStorage.removeItem(cacheKey);
          return null;
        }
        return data.summary;
      } catch {
        return null;
      }
    }

    function setCache(summary) {
      try {
        localStorage.setItem(cacheKey, JSON.stringify({
          summary: summary,
          timestamp: Date.now()
        }));
      } catch {}
    }

    async function generateSummary() {
      loadingEl.style.display = 'flex';
      textEl.style.display = 'none';
      errorEl.style.display = 'none';

      try {
        const response = await fetch('/api/ai-summary/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, content })
        });

        if (!response.ok) {
          throw new Error('API 请求失败');
        }

        const data = await response.json();
        
        if (data.error) {
          throw new Error(data.error);
        }

        const summary = data.summary;
        setCache(summary);
        
        loadingEl.style.display = 'none';
        textEl.textContent = summary;
        textEl.style.display = 'block';
      } catch (err) {
        console.error('AI 摘要生成失败:', err);
        loadingEl.style.display = 'none';
        errorEl.textContent = 'AI 摘要生成失败: ' + (err.message || '未知错误');
        errorEl.style.display = 'block';
      }
    }

    const cachedSummary = getCache();
    if (cachedSummary) {
      loadingEl.style.display = 'none';
      textEl.textContent = cachedSummary;
      textEl.style.display = 'block';
    } else {
      generateSummary();
    }
  })();
</script>

---
import { Icon } from "astro-icon/components";
import WidgetLayout from "@/components/common/WidgetLayout.astro";
import { sidebarLayoutConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getHotPosts } from "@/utils/content-utils";

const hotPosts = await getHotPosts(5);

const COLLAPSED_HEIGHT = "7.5rem";

const hotPostsComponent = [
	...sidebarLayoutConfig.leftComponents,
	...sidebarLayoutConfig.rightComponents,
	...sidebarLayoutConfig.mobileBottomComponents,
].find((c) => c.type === "hotPosts");

const collapseThreshold = hotPostsComponent?.responsive?.collapseThreshold;
const isCollapsed = collapseThreshold
	? hotPosts.length > collapseThreshold
	: false;

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.hotPosts)} id="hot-posts" isCollapsed={isCollapsed} collapsedHeight={COLLAPSED_HEIGHT}
                class={className} style={style}
>
	<ul class="space-y-2">
		{hotPosts.map((post, index) => (
			<li class="hot-post-item group">
				<a href={post.url} class="flex items-start gap-2 py-1.5 px-2 rounded-lg hover:bg-black/5 dark:hover:bg-white/5 transition-colors">
					<span class:list={[
						"flex-shrink-0 w-5 h-5 rounded-full text-xs font-bold flex items-center justify-center",
						index === 0 ? "bg-red-500 text-white" : "",
						index === 1 ? "bg-orange-500 text-white" : "",
						index === 2 ? "bg-yellow-500 text-white" : "",
						index > 2 ? "bg-gray-300 dark:bg-gray-600 text-gray-700 dark:text-gray-300" : ""
					]}>
						{index + 1}
					</span>
					<div class="flex-1 min-w-0">
						<span class="text-sm text-neutral-700 dark:text-neutral-300 group-hover:text-(--primary) transition-colors line-clamp-2">
							{post.title}
						</span>
						<div class="flex items-center gap-1 text-xs text-neutral-500 dark:text-neutral-400 mt-0.5">
							<Icon name="material-symbols:visibility" class="text-xs" />
							<span>{post.views}</span>
						</div>
					</div>
				</a>
			</li>
		))}
	</ul>
</WidgetLayout>
---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getStatisticsSummary, getTopArticles, getCategoryStats } from "@/utils/content-utils";

const summary = await getStatisticsSummary();
const topArticles = await getTopArticles(10);
const categoryStats = await getCategoryStats();

const pageTitle = "数据看板";
---

<MainGridLayout title={pageTitle}>

<div class="statistics-page">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 border-purple-500">
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">文章总数</p>
            <h2 class="text-3xl font-bold text-purple-500">{summary.totalArticles}</h2>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 border-green-500">
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">总阅读量</p>
            <h2 class="text-3xl font-bold text-green-500">{summary.totalViews}</h2>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 border-orange-500">
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">分类数量</p>
            <h2 class="text-3xl font-bold text-orange-500">{summary.totalCategories}</h2>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 border-red-500">
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">标签总数</p>
            <h2 class="text-3xl font-bold text-red-500">{summary.totalTags}</h2>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 border-yellow-500">
            <p class="text-gray-500 dark:text-gray-400 text-sm mb-1">点赞总数</p>
            <h2 class="text-3xl font-bold text-yellow-500">{summary.totalLikes}</h2>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-7 gap-6">
        <div class="lg:col-span-4 bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div id="bar-chart" style="width: 100%; height: 400px;"></div>
        </div>
        <div class="lg:col-span-3 bg-white dark:bg-gray-800 rounded-lg shadow p-4">
            <div id="pie-chart" style="width: 100%; height: 400px;"></div>
        </div>
    </div>
</div>

<script src="https://cdn.staticfile.net/echarts/5.4.3/echarts.min.js"></script>

<script define:vars={{ topArticles, categoryStats }}>
    document.addEventListener('DOMContentLoaded', function() {
        // 准备数据
        const names_raw = topArticles.map(a => a.title);
        const views_raw = topArticles.map(a => a.views);
        const pie_raw = categoryStats.filter(c => c.value > 0).map(c => ({ name: c.name, value: c.value }));

        // 渲染柱状图
        if (names_raw.length > 0 && typeof echarts !== 'undefined') {
            var barChart = echarts.init(document.getElementById('bar-chart'));
            barChart.setOption({
                title: { text: '文章阅读排行榜 (Top 10)', left: 'center' },
                tooltip: { trigger: 'axis' },
                grid: { bottom: '25%' },
                xAxis: { 
                    type: 'category', 
                    data: names_raw, 
                    axisLabel: { rotate: 35, interval: 0, fontSize: 10 } 
                },
                yAxis: { type: 'value', name: '阅读量' },
                series: [{ 
                    name: '阅读量',
                    data: views_raw, 
                    type: 'bar', 
                    itemStyle: { color: '#7367f0', borderRadius: [4, 4, 0, 0] },
                    barWidth: '40%'
                }]
            });
        }

        // 渲染饼图
        if (pie_raw.length > 0 && typeof echarts !== 'undefined') {
            var pieChart = echarts.init(document.getElementById('pie-chart'));
            pieChart.setOption({
                title: { text: '内容分类分布', left: 'center' },
                tooltip: { trigger: 'item', formatter: '{b}: {c} 篇 ({d}%)' },
                legend: { bottom: '0', left: 'center', itemWidth: 8, itemHeight: 8, textStyle: {fontSize: 10} },
                series: [{
                    name: '分类占比',
                    type: 'pie',
                    radius: [30, 120],
                    center: ['50%', '45%'],
                    roseType: 'radius',
                    itemStyle: { borderRadius: 8 },
                    data: pie_raw,
                    color: ['#7367f0', '#32cc70', '#ff9f43', '#ea5455', '#00cfe8', '#82868b']
                }]
            });
        }

        // 响应式缩放
        window.addEventListener('resize', function() {
            if (typeof barChart !== 'undefined') barChart.resize();
            if (typeof pieChart !== 'undefined') pieChart.resize();
        });
    });
</script>

</MainGridLayout>